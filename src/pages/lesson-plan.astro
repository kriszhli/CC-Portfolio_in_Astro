---
import '../styles/global.css';

const SmartCookiePath = `${import.meta.env.BASE_URL}/assets/PDFs/SmartCookie.pdf`;
const MathPath = `${import.meta.env.BASE_URL}/assets/PDFs/Math.pdf`;
const SocialStudiesPath = `${import.meta.env.BASE_URL}/assets/PDFs/SocialStudies.pdf`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/favicon.png`} />
  <title>Lesson Plan - Ms. Qiao</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>
</head>
<body>
  <div id="white-fade-overlay" style="position: fixed; inset: 0; background: white; z-index: 9999; pointer-events: none; opacity: 1; transition: opacity 0.8s ease-out;"></div>
  
  <a href={import.meta.env.BASE_URL} class="back-button interactive-element" aria-label="Back to Desk">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
    </svg>
  </a>

  <main class="binder-wrapper">
    <div class="binder-main">
      <div class="spine">
        <div class="hole"></div>
        <div class="hole"></div>
        <div class="hole"></div>
      </div>
      
      <div class="content-area">
        <div class="page active" id="page-1" role="tabpanel" aria-labelledby="tab-1">
          <div class="pdf-viewer" data-url={SmartCookiePath}>
            <div class="pdf-loading">Loading Reading & SEL Lesson...</div>
            <div class="pdf-render-container"></div>
          </div>
        </div>
        <div class="page" id="page-2" role="tabpanel" aria-labelledby="tab-2" aria-hidden="true" inert>
          <div class="pdf-viewer" data-url={MathPath}>
            <div class="pdf-loading">Loading Math Lesson...</div>
            <div class="pdf-render-container"></div>
          </div>
        </div>
        <div class="page" id="page-3" role="tabpanel" aria-labelledby="tab-3" aria-hidden="true" inert>
          <div class="pdf-viewer" data-url={SocialStudiesPath}>
            <div class="pdf-loading">Loading Social Studies Unit...</div>
            <div class="pdf-render-container"></div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="tabs-container" role="tablist" aria-orientation="vertical">
      <div class="active-bloom"></div>
      
      <button class="binder-tab tab-pink active interactive-element" id="tab-1" role="tab" aria-selected="true" aria-controls="page-1" data-target="page-1">
        <span>Reading & SEL Lesson: <i>The Smart Cookie</i></span>
      </button>
      <button class="binder-tab tab-green interactive-element" id="tab-2" role="tab" aria-selected="false" aria-controls="page-2" data-target="page-2">
        <span>Math Lesson (3 Days): Bar Graphs (TPA)</span>
      </button>
      <button class="binder-tab tab-blue interactive-element" id="tab-3" role="tab" aria-selected="false" aria-controls="page-3" data-target="page-3">
        <span>Social Studies Unit: “Why Do People March?” (UbD)</span>
      </button>
    </div>
  </main>

  <style is:global>
    body {
      background-color: #fafafa;
      margin: 0;
      min-height: 100dvh;
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: 'Space Grotesk', system-ui, -apple-system, sans-serif;
      overflow: hidden;
      padding: 20px;
    }

    .back-button {
      position: fixed;
      top: 24px;
      left: 24px;
      z-index: 150;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      background: rgba(255, 255, 255, 0.5);
      backdrop-filter: blur(2px);
      -webkit-backdrop-filter: blur(2px);
      color: #959595ff;
      border-radius: 50%;
      border: none;
      box-shadow: 
        3px 2px 10px rgba(0,0,0,0.3),
        inset 0 1px 0 rgba(255,255,255,0.2);
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .back-button svg {
      width: 24px;
      height: 24px;
    }

    .back-button:hover, .back-button:focus-visible {
      transform: scale(1.1);
      background: rgba(255, 255, 255, 0.95);
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
      outline: none;
    }

    .binder-wrapper {
      position: relative;
      width: 85vw;
      max-width: 1100px;
      height: 80vh;
      display: flex;
      align-items: stretch;
      margin-top: -20px; 
      filter: 
        drop-shadow(10px 7px 5px rgba(0,0,0,0.65))
        drop-shadow(20px 14px 10px rgba(0,0,0,0.15));
      animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .binder-main {
      flex-grow: 1;
      background: transparent;
      border-radius: 20px 0 0 20px;
      display: flex;
      position: relative;
      z-index: 2;
      border: 1px solid rgba(0, 0, 0, 0.05);
      border-right: none;
      box-shadow: 
        inset 0 1px 1px rgba(255,255,255,1),
        inset 0 -1px 1px rgba(0,0,0,0.02);
    }

    .binder-main::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 32px;
      transform: translate(-50%, -50%);
      width: 100px;
      height: 95%;
      filter: blur(50px);
      transition: all 0.6s ease;
      z-index: -1;
      opacity: 0;
      pointer-events: none;
    }

    .binder-wrapper:has(#tab-1.active) .binder-main::before { 
      opacity: 0.15; 
      background: rgb(255, 0, 132); 
    }
    .binder-wrapper:has(#tab-2.active) .binder-main::before { 
      opacity: 0.15; 
      background: rgb(0, 255, 94); 
    }
    .binder-wrapper:has(#tab-3.active) .binder-main::before { 
      opacity: 0.15; 
      background: rgb(0, 119, 255); 
    }

    .spine {
      width: 64px;
      background: rgba(255, 255, 255, 0.5); 
      border-right: 1px solid rgba(255, 255, 255, 0.5);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: center;
      padding: 80px 0;
      z-index: 10;
      backdrop-filter: blur(8px);
      border-radius: 18px 0 0 18px;
      transition: background 0.6s ease;
      position: relative;
    }

    .binder-wrapper:has(#tab-1.active) .spine { background: rgba(255, 0, 132, 0.2); }
    .binder-wrapper:has(#tab-2.active) .spine { background: rgba(0, 255, 94, 0.2); }
    .binder-wrapper:has(#tab-3.active) .spine { background: rgba(147, 197, 253, 0.2); }


    .hole {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: rgba(0, 0, 0, 0.1);
      box-shadow: 
        inset 0 4px 10px rgba(0,0,0,0.4),
        0 1px 1px rgba(255,255,255,0.2);
    }

    .content-area {
      flex-grow: 1;
      position: relative;
      padding: 0;
      overflow: visible;
      background: #ffffff;
      perspective: 3000px;
      isolation: isolate;
    }

    @media (max-width: 1024px) {
      .binder-wrapper { width: 92vw; height: 85vh; margin-top: 60px; }
      .back-button { top: 20px; left: 20px; width: 44px; height: 44px; }
      .spine { width: 48px; padding: 60px 0; }
    }

    .page {
      --page-flip-duration: 1080ms;
      --page-fade-in-duration: 320ms;
      --page-fade-out-duration: 220ms;
      --page-fade-in-delay: 220ms;
      --page-fade-out-delay: 360ms;
      position: absolute;
      inset: 20px;
      background-color: white;
      border-radius: 8px;
      opacity: 0;
      pointer-events: none;
      overflow: hidden;
      overflow-anchor: none;
      transform-origin: left center;
      transform: rotateY(12deg) scale(0.985);
      transition: 
        transform var(--page-flip-duration) cubic-bezier(0.22, 0.61, 0.36, 1),
        opacity var(--page-fade-out-duration) ease-in var(--page-fade-out-delay);
      backface-visibility: hidden;
      will-change: transform, opacity;
      box-shadow:
        0 0 0 1px rgba(15, 23, 42, 0.04),
        0 18px 40px rgba(15, 23, 42, 0.08);
      z-index: 1;
    }

    .page.active {
      opacity: 1;
      pointer-events: auto;
      transform: rotateY(0deg) scale(1);
      z-index: 2;
      transition: 
        transform var(--page-flip-duration) cubic-bezier(0.16, 1, 0.3, 1),
        opacity var(--page-fade-in-duration) ease-out var(--page-fade-in-delay);
    }

    .page.turned-out {
      transform: rotateY(-120deg) scale(0.95);
      opacity: 0;
      z-index: 3;
      transition:
        transform var(--page-flip-duration) cubic-bezier(0.55, 0.06, 0.68, 0.19),
        opacity var(--page-fade-out-duration) ease-in var(--page-fade-out-delay);
    }

    .pdf-viewer {
      width: 100%;
      height: 100%;
      min-height: 0;
      background: white;
      display: flex;
      flex-direction: column;
      align-items: center;
      overflow-y: auto;
      overflow-x: hidden;
      overflow-anchor: none;
      overscroll-behavior: contain;
      scroll-behavior: auto;
      touch-action: pan-y;
    }

    .pdf-render-container {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding-bottom: 40px;
    }

    .pdf-render-container canvas {
      width: 100% !important;
      height: auto !important;
      display: block;
      border-bottom: 1px solid #f0f0f0; 
      background: white;
    }

    .pdf-loading {
      padding: 60px;
      color: #999;
      font-size: 0.9rem;
      font-style: italic;
    }

    .tabs-container {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 13px;
      z-index: 1;
      height: 100%;
      margin-left: -20px;
      position: relative;
    }

    .active-bloom {
      position: absolute;
      left: 0;
      transform: translate(-30%, -50%);
      width: 400px;
      height: 400px;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0;
      transition: 
        opacity 0.8s ease,
        top 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
        background 0.6s ease;
      pointer-events: none;
      z-index: -1;
    }

    .tabs-container:has(#tab-1.active) .active-bloom { 
      top: 17.8%; 
      opacity: 0.2; 
      background: radial-gradient(circle, rgba(255, 32, 147, 1), transparent 70%); 
    }
    .tabs-container:has(#tab-2.active) .active-bloom { 
      top: 48%; 
      opacity: 0.2; 
      background: radial-gradient(circle, rgba(55, 255, 129, 1), transparent 70%); 
    }
    .tabs-container:has(#tab-3.active) .active-bloom { 
      top: 80.2%; 
      opacity: 0.2; 
      background: radial-gradient(circle, rgba(57, 149, 255, 1), transparent 70%); 
    }

    .binder-tab {
      writing-mode: vertical-rl;
      padding: 16px 12px 16px 28px;
      min-height: 180px; 
      width: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      border: none;
      border-radius: 0 16px 16px 0;
      font-family: inherit;
      font-size: 0.85rem;
      line-height: 1.4;
      font-weight: 600;
      color: #777;
      background: rgba(255, 255, 255, 0.4);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
      position: relative;
      box-shadow: 4px 0 10px rgba(0,0,0,0.05);
      text-align: center;
      word-break: break-word;
    }

    .binder-tab:hover {
      transform: translateX(10px);
      color: #000; 
      background: rgba(255, 255, 255, 0.6);
    }

    .binder-tab.active {
      width: 88px;
      padding-left: 36px;
      transform: translateX(4px);
      z-index: 20;
      box-shadow: 12px 0 30px rgba(0,0,0,0.1);
      color: white;
    }
    
    .tab-pink.active { background: rgba(244, 114, 182, 0.35); }
    .tab-green.active { background: rgba(134, 239, 172, 0.35); }
    .tab-blue.active { background: rgba(147, 197, 253, 0.35); }

    #tab-1 { transform: translateY(1px); }
    #tab-3 { transform: translateY(-1px); }

    .hovering-link { cursor: pointer; }
  </style>

  <script is:inline>
    async function loadPDF(viewer) {
      const pdfjsLib = window.pdfjsLib || window['pdfjs-dist/build/pdf'];
      if (!pdfjsLib) return;

      if (!pdfjsLib.GlobalWorkerOptions.workerSrc) {
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';
      }

      const url = viewer.dataset.url;
      const container = viewer.querySelector('.pdf-render-container');
      const loader = viewer.querySelector('.pdf-loading');
      
      if (!url || container.dataset.loaded === "true") return;

      try {
        const loadingTask = pdfjsLib.getDocument(url);
        const pdf = await loadingTask.promise;
        
        container.innerHTML = '';
        const dpr = window.devicePixelRatio || 1;
        
        for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
          const page = await pdf.getPage(pageNum);
          const initialViewport = page.getViewport({ scale: 1 });
          const baseScale = (container.clientWidth) / initialViewport.width;
          const viewport = page.getViewport({ scale: baseScale * dpr });

          const canvas = document.createElement('canvas');
          const context = canvas.getContext('2d');
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          canvas.style.width = "100%";
          canvas.style.height = "auto";

          const renderContext = {
            canvasContext: context,
            viewport: viewport,
            intent: 'display'
          };
          
          await page.render(renderContext).promise;
          container.appendChild(canvas);
        }
        
        container.dataset.loaded = "true";
        if (loader) loader.style.display = 'none';
      } catch (error) {
        console.error('Error loading PDF:', error);
        if (loader) loader.textContent = 'Failed to load PDF.';
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const overlay = document.getElementById('white-fade-overlay');
      const backButton = document.querySelector('.back-button');
      const tabs = document.querySelectorAll('.binder-tab');
      const pages = document.querySelectorAll('.page');
      const PAGE_FLIP_DURATION = 1080;

      if (overlay) {
        setTimeout(() => {
          overlay.style.opacity = '0';
        }, 50);
      }

      if (backButton && overlay) {
        backButton.addEventListener('click', (e) => {
          e.preventDefault();
          const targetHref = backButton.getAttribute('href');

          document.body.style.pointerEvents = 'none';
          overlay.style.transition = 'opacity 0.2s ease';
          overlay.style.opacity = '1';

          setTimeout(() => {
            window.location.href = targetHref;
          }, 150);
        });
      }

      const resetPageScroll = (page) => {
        page.scrollTop = 0;
        page.scrollLeft = 0;

        const viewer = page.querySelector('.pdf-viewer');
        if (!viewer) return;

        viewer.scrollTop = 0;
        viewer.scrollLeft = 0;
      };

      const schedulePageScrollReset = (page) => {
        resetPageScroll(page);
        requestAnimationFrame(() => {
          resetPageScroll(page);
          requestAnimationFrame(() => resetPageScroll(page));
        });
        setTimeout(() => resetPageScroll(page), 80);
      };

      const activatePage = (page) => {
        page.removeAttribute('aria-hidden');
        page.removeAttribute('inert');
        page.classList.add('active');
      };

      const deactivatePage = (page) => {
        page.setAttribute('aria-hidden', 'true');
        page.setAttribute('inert', '');
      };
      
      const waitForLib = () => {
        const pdfjsLib = window.pdfjsLib || window['pdfjs-dist/build/pdf'];
        if (pdfjsLib) {
          init();
        } else {
          setTimeout(waitForLib, 100);
        }
      };

      const init = () => {
        const activeViewer = document.querySelector('.page.active .pdf-viewer');
        if (activeViewer) loadPDF(activeViewer);

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const targetId = tab.getAttribute('data-target');
            if (!targetId) return;

            const currentPage = document.querySelector('.page.active');
            if (currentPage?.id === targetId) {
              schedulePageScrollReset(currentPage);
              return;
            }

            tabs.forEach(t => {
              t.classList.remove('active');
              t.setAttribute('aria-selected', 'false');
            });
            tab.classList.add('active');
            tab.setAttribute('aria-selected', 'true');

            pages.forEach((p) => {
              const isTarget = p.id === targetId;
              const isCurrent = currentPage && p === currentPage;

              p.classList.remove('active', 'turned-out');

              if (isTarget) {
                p.removeAttribute('aria-hidden');
                p.removeAttribute('inert');
                schedulePageScrollReset(p);
                requestAnimationFrame(() => {
                  activatePage(p);
                  schedulePageScrollReset(p);
                });
                const viewer = p.querySelector('.pdf-viewer');
                if (viewer) {
                  loadPDF(viewer).finally(() => schedulePageScrollReset(p));
                }
                return;
              }

              if (isCurrent) {
                p.classList.add('turned-out');
              }

              setTimeout(() => {
                if (!p.classList.contains('active')) {
                  resetPageScroll(p);
                  deactivatePage(p);
                  p.classList.remove('turned-out');
                }
              }, PAGE_FLIP_DURATION);
            });
          });
        });
      };

      waitForLib();

      const isTouchDevice = window.matchMedia('(hover: none), (pointer: coarse)').matches || navigator.maxTouchPoints > 0;
      if (!isTouchDevice) {
        const interactiveElements = document.querySelectorAll('.interactive-element');
        interactiveElements.forEach(el => {
          el.addEventListener('mouseenter', () => document.body.classList.add('hovering-link'));
          el.addEventListener('mouseleave', () => document.body.classList.remove('hovering-link'));
        });
      }
    });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        document.querySelectorAll('.pdf-render-container').forEach(container => {
          container.dataset.loaded = "false";
          const viewer = container.closest('.pdf-viewer');
          const page = container.closest('.page');
          if (page && page.classList.contains('active')) {
            loadPDF(viewer);
          }
        });
      }, 500);
    });
  </script>
</body>
</html>
