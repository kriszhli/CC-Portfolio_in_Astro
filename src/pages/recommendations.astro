---
// Professional LORs
import LOR_1 from '../assets/PNGs/LOR_1.png';
import LOR_2_1 from '../assets/PNGs/LOR_2.1.png';
import LOR_2_2 from '../assets/PNGs/LOR_2.2.png';
import LOR_3 from '../assets/PNGs/LOR_3.png';

// Student LORs
import LOR_Stu_1 from '../assets/PNGs/LOR_Stu_1.png';
import LOR_Stu_2 from '../assets/PNGs/LOR_Stu_2.png';
import LOR_Stu_3 from '../assets/PNGs/LOR_Stu_3.png';

const profSrcs = [LOR_1.src, LOR_2_1.src, LOR_2_2.src, LOR_3.src];
const stuSrcs  = [LOR_Stu_1.src, LOR_Stu_2.src, LOR_Stu_3.src];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recommendations | Ms. Cici Qiao</title>
  <meta name="description" content="Letters of Recommendation for Ms. Cici Qiao" />

  <!--
    ALL styles live here in <head> as a raw <style> tag (no Astro scoping).
    Using is:global ensures Astro strips its hash-based scoping so that:
      • dynamically injected elements (lor-img, pos-* etc.) get these rules
      • the mag-overlay (position:fixed) works without overflow clipping
  -->
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #fff;
    }

    body {
      width: 100vw;
      min-height: 100vh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      overflow: auto;
      overflow-x: hidden;
      padding: 96px 24px 56px;
    }

    /* ── Back button ─────────────────────────── */
    .back-btn {
      position: fixed;
      top: 28px;
      left: 28px;
      z-index: 100;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      color: #FF69B4;
      font-size: 1rem;
      font-weight: 600;
      padding: 8px 18px;
      border-radius: 30px;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(8px);
      box-shadow: 0 2px 12px rgba(0,0,0,0.12);
      transition: transform 0.2s ease;
    }
    .back-btn:hover { transform: translateX(-4px); }

    /* ── Page layout ─────────────────────────── */
    /*
      The left column stays fixed so the toggle sits beside the stack.
      The outer wrapper is centered by body flexbox.
    */
    .page-layout {
      display: grid;
      grid-template-columns: 260px auto;
      align-items: center;
      justify-content: center;
      column-gap: 72px;
      width: min(100%, 1180px);
      margin: 0 auto;
    }

    .left-col {
      display: flex;
      justify-content: center;
      align-items: center;
      justify-self: end;
    }

    .right-col {
      display: flex;
      justify-content: center;
      align-items: center;
      justify-self: start;
    }

    .center-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 36px;
      justify-self: center;
    }

    /* ── Stack container ─────────────────────── */
    .stack-area {
      position: relative;
      width: 400px;
      height: 520px;
      flex-shrink: 0;
    }

    /* lor-img: JS-injected images.  Must use is:global above to reach these. */
    .lor-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 4px;
      filter: drop-shadow(0 12px 28px rgba(0,0,0,0.14));
      transition: transform 0.5s cubic-bezier(0.25,1,0.5,1),
                  opacity  0.5s cubic-bezier(0.25,1,0.5,1);
      will-change: transform, opacity;
    }

    /* Stack position classes ─ also JS-injected */
    .pos-0 { z-index:10; transform: rotate(0deg)   translate(0, 0)      scale(1);    opacity:1;    pointer-events:auto; }
    .pos-1 { z-index:9;  transform: rotate(2.5deg) translate(10px,6px)  scale(0.97); opacity:0.92; pointer-events:none; }
    .pos-2 { z-index:8;  transform: rotate(-2deg)  translate(-8px,12px) scale(0.94); opacity:0.85; pointer-events:none; }
    .pos-3 { z-index:7;  transform: rotate(1deg)   translate(4px,18px)  scale(0.91); opacity:0.78; pointer-events:none; }
    .pos-hidden { z-index:0; transform:scale(0.85); opacity:0; pointer-events:none; }

    /* ── Arrow controls ──────────────────────── */
    .controls {
      display: flex;
      gap: 120px;
      align-items: center;
    }

    .counter {
      font-size: 1.25rem;
      font-weight: 700;
      color: #FF69B4;
      font-variant-numeric: tabular-nums;
      min-width: 3ch;
      text-align: center;
    }

    .arrow {
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      color: #FF69B4;
      transition: transform 0.18s ease;
    }
    .arrow:hover { transform: scale(1.25); }
    .arrow svg  { width: 38px; height: 38px; }

    /* ── Toggle ──────────────────────────────── */
    .toggle-wrap {
      position: relative;
      height: 58px;
      width: 260px;
      background: #FF69B4;
      border-radius: 29px;
      cursor: pointer;
      display: flex;
      align-items: center;
      box-shadow: 0 4px 14px rgba(255,105,180,0.35);
      user-select: none;
      overflow: hidden;
    }

    .toggle-knob {
      position: absolute;
      top: 5px;
      left: 5px;
      width: 125px;
      height: 48px;
      background: #fff;
      border-radius: 24px;
      transition: transform 0.4s cubic-bezier(0.25,1,0.5,1);
      z-index: 1;
    }

    .toggle-lbl {
      flex: 1;
      text-align: center;
      font-size: 15px;
      font-weight: 600;
      pointer-events: none;
      z-index: 2;
      transition: color 0.4s ease;
    }

    /* Student active (knob on right) */
    .toggle-wrap.stu .toggle-knob          { transform: translateX(125px); }
    .toggle-wrap.stu .toggle-lbl.lbl-prof  { color: #fff; }
    .toggle-wrap.stu .toggle-lbl.lbl-stu   { color: #FF69B4; }

    /* Professional active (knob on left) */
    .toggle-wrap.prof .toggle-knob         { transform: translateX(0); }
    .toggle-wrap.prof .toggle-lbl.lbl-prof { color: #FF69B4; }
    .toggle-wrap.prof .toggle-lbl.lbl-stu  { color: #fff; }

  </style>
</head>
<body>

  <a href="/CC-Portfolio_in_Astro/" class="back-btn">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 12H5M12 19l-7-7 7-7"/>
    </svg>
    Back
  </a>

  <div class="page-layout">

    <!-- LEFT col: toggle -->
    <div class="left-col">
      <div class="toggle-wrap stu" id="type-toggle">
        <div class="toggle-knob"></div>
        <span class="toggle-lbl lbl-prof">Professional</span>
        <span class="toggle-lbl lbl-stu">Student</span>
      </div>
    </div>

    <!-- CENTER col: stack + controls -->
    <div class="center-col">
      <div class="stack-area" id="stack-area"></div>
      <div class="controls">
        <button class="arrow" id="prev-btn" aria-label="Previous">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <div class="counter" id="counter">1/3</div>
        <button class="arrow" id="next-btn" aria-label="Next">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <script define:vars={{ profSrcs, stuSrcs }}>
    document.addEventListener('DOMContentLoaded', () => {
      // Display number maps: LOR_2.1 and LOR_2.2 both display as "2"
      const profMap   = [1, 2, 2, 3];
      const stuMap    = [1, 2, 3];
      const profTotal = 3;
      const stuTotal  = 3;

      let mode     = 'student';
      let images   = stuSrcs;
      let numMap   = stuMap;
      let total    = stuTotal;
      let idx      = 0;
      let imgEls   = [];

      const stackEl   = document.getElementById('stack-area');
      const toggleEl  = document.getElementById('type-toggle');
      const counterEl = document.getElementById('counter');
      const prevBtn   = document.getElementById('prev-btn');
      const nextBtn   = document.getElementById('next-btn');

      // ── Stack rendering ────────────────────────────────────────────────
      const POS = ['pos-0','pos-1','pos-2','pos-3','pos-hidden'];

      function render() {
        imgEls.forEach((el, i) => {
          POS.forEach(c => el.classList.remove(c));
          const rel = (i - idx + images.length) % images.length;
          el.classList.add(rel <= 3 ? `pos-${rel}` : 'pos-hidden');
        });
        counterEl.textContent = `${numMap[idx]}/${total}`;
      }

      function buildStack() {
        stackEl.innerHTML = '';
        imgEls = [];
        idx = 0;
        images.forEach(src => {
          const img = document.createElement('img');
          img.src = src;
          img.draggable = false;
          img.className = 'lor-img'; // styled by is:global above
          stackEl.appendChild(img);
          imgEls.push(img);
        });
        render();
      }

      buildStack();

      prevBtn.addEventListener('click', () => { idx = (idx - 1 + images.length) % images.length; render(); });
      nextBtn.addEventListener('click', () => { idx = (idx + 1) % images.length; render(); });

      // ── Toggle ─────────────────────────────────────────────────────────
      toggleEl.addEventListener('click', () => {
        if (mode === 'student') {
          mode = 'professional';
          images = profSrcs; numMap = profMap; total = profTotal;
          toggleEl.classList.replace('stu', 'prof');
        } else {
          mode = 'student';
          images = stuSrcs; numMap = stuMap; total = stuTotal;
          toggleEl.classList.replace('prof', 'stu');
        }
        buildStack();
      });
    });
  </script>

</body>
</html>
